// Fable MVP database — the institution console and demo bank both read/write
// here through Next.js API routes. SQLite for local/hackathon; swap the
// datasource provider to postgresql for production with no model changes.
//
// SQLite has no native enums or JSON columns, so status/level/action/channel
// are plain strings and Shield's signal list is stored as a JSON string.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

/// A bank, fintech, or mobile-money operator that plugs into Fable.
model Institution {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  type      String // "Microfinance Bank", "Commercial Bank", "Fintech", ...
  email     String   @default("")
  createdAt DateTime @default(now())

  users        User[]
  transactions Transaction[]
}

/// A banking customer whose account is used in the demo bank.
model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  accountNumber String   @unique
  balance       Float    @default(0)
  createdAt     DateTime @default(now())

  institution   Institution @relation(fields: [institutionId], references: [id])
  institutionId String

  transactions Transaction[]
}

/// A transfer record. Every transfer — safe or not — is persisted here.
/// Recipient details are denormalized (recipients can be any external
/// account, including deliberately "Unknown" ones), and customerName is
/// denormalized so the institution feed can carry many customers without a
/// User row for each. The demo user's own transfers also link via userId.
model Transaction {
  id               String   @id @default(cuid())
  amount           Float
  currency         String   @default("NGN")
  direction        String   @default("debit") // debit | credit
  channel          String   @default("app") // app | ussd | web | pos | atm
  narration        String   @default("")
  customerName     String
  recipientName    String
  recipientBank    String
  recipientAccount String
  status           String   @default("completed") // completed | blocked | cancelled | held | released
  live             Boolean  @default(false)
  createdAt        DateTime @default(now())

  institution   Institution @relation(fields: [institutionId], references: [id])
  institutionId String
  user          User?       @relation(fields: [userId], references: [id])
  userId        String?

  evaluation RiskEvaluation?
  ghost      GhostContainer?

  @@index([institutionId, createdAt])
}

/// The Fable intelligence record attached to a transaction (Shield's verdict).
model RiskEvaluation {
  id          String   @id @default(cuid())
  riskScore   Float // 0..1
  riskLevel   String // LOW | MEDIUM | HIGH
  action      String // PASS | FLAG | BLOCK
  signals     String   @default("[]") // JSON-encoded Signal[]
  explanation String   @default("")
  latencyMs   Int      @default(0)
  agent       String   @default("fable-shield-v1")
  createdAt   DateTime @default(now())

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String      @unique
}

/// A Ghost cooling-window container for an overridden high-risk transfer.
model GhostContainer {
  id            String    @id @default(cuid())
  amount        Float
  status        String    @default("held") // held | cancelled | released
  windowSeconds Int       @default(900)
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String      @unique
}
